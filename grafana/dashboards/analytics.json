          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n              bucket AS time,\n              metric,\n              value\n            FROM (\n              SELECT\n                $__timeGroup(tm.ts, '5m') AS bucket,\n                'CPU %' AS metric,\n                ROUND(AVG(tm.cpu_usage)::NUMERIC, 1) AS value\n              FROM telemetry_metrics tm\n              JOIN assets a USING (asset_id)\n              WHERE $__timeFilter(tm.ts) AND (${room:raw} = 'All' OR a.room_name = ${room:raw})\nAND (${rack:raw} = 'All' OR a.rack_name = ${rack:raw})\nAND (${server:raw} = 'All' OR a.asset_name = ${server:raw})\n              GROUP BY 1\n              UNION ALL\n              SELECT\n                $__timeGroup(tm.ts, '5m') AS bucket,\n                'Outlet Temp' AS metric,\n                ROUND(AVG(tm.outlet_temp_c)::NUMERIC, 1) AS value\n              FROM telemetry_metrics tm\n              JOIN assets a USING (asset_id)\n              WHERE $__timeFilter(tm.ts) AND (${room:raw} = 'All' OR a.room_name = ${room:raw})\nAND (${rack:raw} = 'All' OR a.rack_name = ${rack:raw})\nAND (${server:raw} = 'All' OR a.asset_name = ${server:raw})\n              GROUP BY 1\n            ) s\n            ORDER BY 1, 2",
          "refId": "A"
        }
      ],
      "title": "CPU and Thermal Drift",
