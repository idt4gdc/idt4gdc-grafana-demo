          "rawSql": "SELECT\n              $__timeGroupAlias(tm.ts, '5m'),\n              'Observed Power' AS metric,\n              ROUND(SUM(tm.power_w)::NUMERIC, 1) AS value\n            FROM telemetry_metrics tm\n            JOIN assets a USING (asset_id)\n            WHERE $__timeFilter(tm.ts) AND (${room:raw} = 'All' OR a.room_name = ${room:raw})\nAND (${rack:raw} = 'All' OR a.rack_name = ${rack:raw})\nAND (${server:raw} = 'All' OR a.asset_name = ${server:raw})\n            GROUP BY 1\n            ORDER BY 1",
