          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT step AS \"Step\", status AS \"Status\"\nFROM (\n  SELECT 1 AS sort_order, 'Transactions received' AS step,\n    CASE\n      WHEN ${scenario_phase:raw} IN ('running', 'scheduler', 'gpu_training', 'fpga_inference', 'optimised') THEN 'complete'\n      ELSE 'active'\n    END AS status\n  UNION ALL\n  SELECT 2, 'CPU baseline execution',\n    CASE\n      WHEN ${scenario_phase:raw} = 'baseline' THEN 'active'\n      WHEN ${scenario_phase:raw} IN ('running', 'scheduler', 'gpu_training', 'fpga_inference', 'optimised') THEN 'complete'\n      ELSE 'pending'\n    END\n  UNION ALL\n  SELECT 3, 'AI scheduler selects hardware',\n    CASE\n      WHEN ${scenario_phase:raw} = 'scheduler' THEN 'active'\n      WHEN ${scenario_phase:raw} IN ('gpu_training', 'fpga_inference', 'optimised') THEN 'complete'\n      ELSE 'pending'\n    END\n  UNION ALL\n  SELECT 4, 'GPU training starts',\n    CASE\n      WHEN ${scenario_phase:raw} = 'gpu_training' THEN 'active'\n      WHEN ${scenario_phase:raw} IN ('fpga_inference', 'optimised') THEN 'complete'\n      ELSE 'pending'\n    END\n  UNION ALL\n  SELECT 5, 'FPGA scoring starts',\n    CASE\n      WHEN ${scenario_phase:raw} = 'fpga_inference' THEN 'active'\n      WHEN ${scenario_phase:raw} = 'optimised' THEN 'complete'\n      ELSE 'pending'\n    END\n  UNION ALL\n  SELECT 6, 'Suspicious transactions flagged',\n    CASE\n      WHEN ${scenario_phase:raw} = 'optimised' THEN 'complete'\n      ELSE 'pending'\n    END\n  UNION ALL\n  SELECT 7, 'Energy / performance improvement displayed',\n    CASE\n      WHEN ${scenario_phase:raw} = 'optimised' THEN 'complete'\n      ELSE 'pending'\n    END\n) flow\nORDER BY sort_order",
          "refId": "A"
        }
      ],
      "title": "Fraud Detection Workload Demo",
      "type": "table"
