          "rawSql": "SELECT\n              l.ts AS \"Last update\",\n              a.room_name AS \"Room\",\n              a.rack_name AS \"Rack\",\n              a.asset_name AS \"Server\",\n              a.asset_type AS \"Type\",\n              ROUND(l.cpu_usage::NUMERIC, 1) AS \"CPU %\",\n              ROUND(l.power_w::NUMERIC, 0) AS \"Power W\",\n              ROUND(l.outlet_temp_c::NUMERIC, 1) AS \"Outlet C\",\n              l.status_level AS \"Status\",\n              l.operational_state AS \"State\"\n            FROM latest_asset_metrics l\n            JOIN assets a USING (asset_id)\n            WHERE (${room:raw} = 'All' OR a.room_name = ${room:raw})\nAND (${rack:raw} = 'All' OR a.rack_name = ${rack:raw})\nAND (${server:raw} = 'All' OR a.asset_name = ${server:raw})\n            ORDER BY\n              CASE l.status_level\n                WHEN 'critical' THEN 1\n                WHEN 'warning' THEN 2\n                ELSE 3\n              END,\n              l.cpu_usage DESC\n            LIMIT 25",
          "refId": "A"
        }
