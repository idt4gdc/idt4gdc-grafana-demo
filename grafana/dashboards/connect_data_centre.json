      "id": 2,
      "options": {
        "content": "<div style=\"padding:8px 4px;\">\n                  <div style=\"font-size:24px; font-weight:800; color:#f3f6fb; margin-bottom:8px;\">Profile Presets</div>\n                  <div style=\"color:#c5cfdd; font-size:14px; line-height:1.5; margin-bottom:14px;\">\n                    Use one of the prepared profiles below to prefill the fake connection fields, or adjust the variable controls manually.\n                  </div>\n                  <div style=\"display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:12px;\">\n          <a href=\"/d/idt4-connect/connect-data-centre?refresh=10s&var-data_centre=%27Turkey%20Data%20Centre%27&var-site_location=Istanbul%2C%20Turkey&var-site_ip=10.40.18.21&var-username=ops_tr&var-password=demo-pass\" style=\"display:block; padding:14px; border-radius:14px; background:#111827; border:1px solid #243244; color:#e5edf8; text-decoration:none;\">\n  <div style=\"font-size:16px; font-weight:700; color:#ffffff; margin-bottom:6px;\">Turkey Data Centre</div>\n  <div style=\"font-size:13px; color:#93a1b5; line-height:1.5;\">Istanbul, Turkey</div>\n  <div style=\"font-size:13px; color:#93a1b5;\">10.40.18.21 \u00b7 OpenDCIM Gateway</div>\n  <div style=\"margin-top:10px; display:inline-block; padding:8px 12px; border-radius:10px; background:#1d4ed8; color:#ffffff; font-size:12px; font-weight:700;\">Use Profile</div>\n</a><a href=\"/d/idt4-connect/connect-data-centre?refresh=10s&var-data_centre=%27UK%20Data%20Centre%27&var-site_location=Manchester%2C%20United%20Kingdom&var-site_ip=10.80.24.12&var-username=ops_uk&var-password=demo-pass\" style=\"display:block; padding:14px; border-radius:14px; background:#111827; border:1px solid #243244; color:#e5edf8; text-decoration:none;\">\n  <div style=\"font-size:16px; font-weight:700; color:#ffffff; margin-bottom:6px;\">UK Data Centre</div>\n  <div style=\"font-size:13px; color:#93a1b5; line-height:1.5;\">Manchester, United Kingdom</div>\n  <div style=\"font-size:13px; color:#93a1b5;\">10.80.24.12 \u00b7 Prometheus Bridge</div>\n  <div style=\"margin-top:10px; display:inline-block; padding:8px 12px; border-radius:10px; background:#1d4ed8; color:#ffffff; font-size:12px; font-weight:700;\">Use Profile</div>\n</a><a href=\"/d/idt4-connect/connect-data-centre?refresh=10s&var-data_centre=%27Demo%20Local%20Data%20Centre%27&var-site_location=Local%20Simulation&var-site_ip=127.0.0.1&var-username=bitnet&var-password=datatwin\" style=\"display:block; padding:14px; border-radius:14px; background:#111827; border:1px solid #243244; color:#e5edf8; text-decoration:none;\">\n  <div style=\"font-size:16px; font-weight:700; color:#ffffff; margin-bottom:6px;\">Demo Local Data Centre</div>\n  <div style=\"font-size:13px; color:#93a1b5; line-height:1.5;\">Local Simulation</div>\n  <div style=\"font-size:13px; color:#93a1b5;\">127.0.0.1 \u00b7 Local Telemetry Stream</div>\n  <div style=\"margin-top:10px; display:inline-block; padding:8px 12px; border-radius:10px; background:#1d4ed8; color:#ffffff; font-size:12px; font-weight:700;\">Use Profile</div>\n</a>\n        </div>\n                </div>",
